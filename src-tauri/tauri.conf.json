{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "轻单",
  "version": "0.20.0",
  "identifier": "com.qingdan.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "轻单",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "language": {
          "zh-CN": {
            "localePath": "./wix/zh-CN.wxl"
          }
        }
      }
    }
  }
}
